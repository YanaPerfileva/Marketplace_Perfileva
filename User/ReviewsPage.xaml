<Page x:Class="User.RevewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:User"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RevewsPage">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>
    <GroupBox Header="{Binding FullName, StringFormat='Отзывы пользователя: {0}'}" Grid.Column="1" Margin="15" Padding="5" FontWeight="SemiBold" Background="#F0F2F5" FontSize="14">
        <Grid Background="#F0F2F5">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" >
                    <GroupBox Header="Оставить отзыв" Margin="0,0,0,20" Background="White">
                        <StackPanel >
                            <TextBlock Text="Выберите товар для отзыва:" FontSize="12"/>
                            <ComboBox x:Name="ProductComboBox" 
              ItemsSource="{Binding AllProducts}" 
              DisplayMemberPath="Name" 
              SelectedValuePath="Id" 
              Margin="0,5,0,0"/>
                            <UniformGrid Columns="2" Margin="0,0,0,10">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Ваша оценка (1-5):" FontSize="12"/>
                                    <ComboBox x:Name="RatingCombo" SelectedIndex="4">
                                        <ComboBoxItem Content="5 ⭐⭐⭐⭐⭐"/>
                                        <ComboBoxItem Content="4 ⭐⭐⭐⭐"/>
                                        <ComboBoxItem Content="3 ⭐⭐⭐"/>
                                        <ComboBoxItem Content="2 ⭐⭐"/>
                                        <ComboBoxItem Content="1 ⭐"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Заголовок:" FontSize="12"/>
                                    <TextBox x:Name="ReviewTitleBox" Text="Кратко о главном..."/>
                                </StackPanel>
                            </UniformGrid>
                            <TextBlock Text="Ваш комментарий:" FontSize="12"/>
                            <TextBox x:Name="ReviewCommentBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5"/>
                            <Button  x:Name="Publish" Content="Опубликовать отзыв" 
                Click="SubmitReview_Click"
                Background="#27AE60" Foreground="White" 
                Padding="15,8" HorizontalAlignment="Right" Cursor="Hand"/>
                        </StackPanel>
                    </GroupBox>
                    <ItemsControl ItemsSource="{Binding Reviews}">
                        <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="8" Margin="0,0,0,15" Padding="15">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#CCCCCC"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <!-- Верхняя строка: Товар, Автор и Оценка -->
                                        <DockPanel LastChildFill="False" Margin="0,0,0,10">
                                            <StackPanel DockPanel.Dock="Left">
                                                <!-- ИМЯ ТОВАРА -->
                                                <TextBlock Text="{Binding Product.Name}" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                                                <!-- ИМЯ АВТОРА (Добавлено) -->
                                                <TextBlock Text="{Binding User.FullName, StringFormat='Автор: {0}'}" FontSize="12" Foreground="#3498DB" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <!-- РЕЙТИНГ -->
                                            <Border Background="#FFC107" CornerRadius="4" Padding="5,2" DockPanel.Dock="Right" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Rating, StringFormat='⭐ {0}'}" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </DockPanel>
                                        <!-- Заголовок отзыва -->
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="13"/>
                                        <!-- Текст отзыва -->
                                        <TextBlock Text="{Binding Comment}" TextWrapping="Wrap" Foreground="#444" Margin="0,0,0,10"/>
                                        <!-- Футер: Дата и проверка покупки -->
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
 </GroupBox>
</Page>
