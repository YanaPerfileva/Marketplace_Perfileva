<Page x:Class="User.ProductDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:User"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductDetailsPage">
    <GroupBox Header="Товар" Grid.Column="1" Margin="15" Padding="5" FontWeight="SemiBold" Background="#F0F2F5" FontSize="14">
        <Grid Background="#F0F2F5" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Кнопка назад -->
            <RowDefinition Height="*"/>
            <!-- Контент -->
        </Grid.RowDefinitions>
        <!-- Кнопка Назад -->
            <Button Content="← К списку заказов" Click="BackClick" HorizontalAlignment="Left" Margin="0,0,0,15"/>
            <Grid Grid.Row="1" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <!-- Колонка фото -->
                    <ColumnDefinition Width="*"/>
                    <!-- Колонка инфо -->
                </Grid.ColumnDefinitions>
                <!-- Левая часть: Фото -->
                <Border Grid.Column="0" Background="White" CornerRadius="15" VerticalAlignment="Top" Padding="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    <Image x:Name="ProductImage" Height="320" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <!-- Правая часть: Описание -->
                <StackPanel Grid.Column="1" Margin="30,0,0,0">
                    <TextBlock x:Name="ProductName" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <TextBlock x:Name="Seller" FontSize="14" Foreground="Gray" Margin="0,0,0,20"/>
                    <Separator Background="#DDD" Margin="0,0,0,20"/>
                    <TextBlock Text="Описание товара" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ProductDescription" TextWrapping="Wrap" FontSize="15" LineHeight="22" Foreground="#444"/>
                    </ScrollViewer>
                    <TextBlock Text="Выберите размер:" FontSize="14" FontWeight="SemiBold" Margin="0,15,0,5"/>
                    <ComboBox x:Name="SizeComboBox" Width="150" HorizontalAlignment="Left" SelectionChanged="SkuSelectionChanged"/>
                    <TextBlock x:Name="Color"  Text="Выберите цвет:" FontSize="14" FontWeight="SemiBold" Margin="0,10,0,5"/>
                    <Border MinHeight="50" VerticalAlignment="Top">
                        <!-- Резервируем место -->
                        <ItemsControl x:Name="ColorSelector">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="35" Height="35" Margin="5" Background="{Binding ColorHex}" Click="Color_Click" Tag="{Binding ColorHex}">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="17"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,5">
                        <TextBlock Text="На складе: " FontSize="14" Foreground="Gray"/>
                        <TextBlock x:Name="StockStatus" FontSize="14" FontWeight="Bold" Foreground="#444"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <TextBlock x:Name="ProductPrice" FontSize="32" Foreground="#E64A19" FontWeight="Black" VerticalAlignment="Center"/>
                        <Button x:Name="AddToCartButton" Content="В корзину" Margin="30,0,0,0" Padding="20,10" Background="#E64A19" Foreground="Black" BorderBrush="Black" FontWeight="Bold" Click="AddToCartButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
  </GroupBox>
</Page>
