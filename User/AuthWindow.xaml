<Window x:Class="User.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:User"
        mc:Ignorable="d"
        Title="Авторизация" Height="550" Width="400" 
        WindowStartupLocation="CenterScreen" Background="LightBlue">
    <Window.Resources>
        <!-- Тот же стиль кнопок из главного меню -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#667eea" Offset="0.0"/>
                        <GradientStop Color="#764ba2" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="15" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Стиль для полей ввода -->
        <Style TargetType="Control" x:Key="InputStyle">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- Общий фон с градиентом -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#667eea" Offset="0.2"/>
                    <GradientStop Color="#764ba2" Offset="0.7"/>
                    <GradientStop Color="#f093fb" Offset="1.0"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <!-- Карточка формы -->
        <Border Background="White" CornerRadius="25" Margin="30" Opacity="0.95">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.2"/>
            </Border.Effect>
            <Grid Margin="30,20">
                <!-- Панель Входа -->
                <StackPanel x:Name="LoginPanel" Visibility="Visible" VerticalAlignment="Center">
                    <TextBlock Text="Вход в аккаунт" FontSize="26" FontWeight="Bold" Foreground="#2d3748" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                    <TextBlock Text="Email" Foreground="#4a5568" FontWeight="Medium"/>
                    <TextBox x:Name="LoginEmail" Style="{StaticResource InputStyle}"/>

                    <TextBlock Text="Пароль" Foreground="#4a5568" FontWeight="Medium"/>
                    <PasswordBox x:Name="LoginPass" Style="{StaticResource InputStyle}"/>

                    <Button Content="Войти" Click="BtnLogin_Click" Style="{StaticResource RoundedButtonStyle}" Height="45" Margin="0,10,0,0"/>

                    <Button Content="Создать новый аккаунт" Click="TogglePanels_Click" 
                            Background="Transparent" BorderThickness="0" Foreground="#764ba2" 
                            FontWeight="SemiBold" Margin="0,15,0,0"/>
                </StackPanel>
                <!-- Панель Регистрации -->
                <StackPanel x:Name="RegisterPanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock Text="Регистрация" FontSize="26" FontWeight="Bold" Foreground="#2d3748" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                    <TextBlock Text="ФИО" Foreground="#4a5568" FontSize="13"/>
                    <TextBox x:Name="RegName" Style="{StaticResource InputStyle}" Height="35"/>

                    <TextBlock Text="Телефон" Foreground="#4a5568" FontSize="13"/>
                    <TextBox x:Name="RegPhone" Style="{StaticResource InputStyle}" Height="35" MaxLength="11" PreviewTextInput="RegPhone_PreviewTextInput"/>

                    <TextBlock Text="Email" Foreground="#4a5568" FontSize="13"/>
                    <TextBox x:Name="RegEmail" Style="{StaticResource InputStyle}" Height="35"/>

                    <TextBlock Text="Пароль" Foreground="#4a5568" FontSize="13"/>
                    <PasswordBox x:Name="RegPass" Style="{StaticResource InputStyle}" Height="35"/>

                    <Button Content="Зарегистрироваться" Click="BtnRegister_Click" Style="{StaticResource RoundedButtonStyle}" Height="45" Margin="0,10,0,0"/>

                    <Button Content="Уже есть профиль? Войти" Click="TogglePanels_Click" 
                            Background="Transparent" BorderThickness="0" Foreground="#764ba2" 
                            FontWeight="SemiBold" Margin="0,15,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
