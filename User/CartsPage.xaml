<Page x:Class="User.CartsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:User"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CartsPage">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <GroupBox Header="Корзина" Margin="15" Padding="5" FontWeight="SemiBold" Background="#F0F2F5" FontSize="16">
            <DataGrid x:Name="CartGrid" ItemsSource="{Binding}" IsReadOnly="True" AutoGenerateColumns="False" SelectionMode="Single">
                <DataGrid.Columns>
                    <!-- Ваши колонки (Фото, Товар, Бренд и т.д.) -->
                    <DataGridTemplateColumn Header="Фото" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="5">
                                    <Border Width="80" Height="35" Background="#F0F0F0" CornerRadius="8">
                                        <TextBlock Text="📦" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Width="60" Height="60" CornerRadius="8" ClipToBounds="True">
                                        <Image Source="{Binding ProductSku.Product.MainImageUrl}" Stretch="UniformToFill"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductSku.Product.Name}" Width="*" ElementStyle="{StaticResource CellCenter}" />
                    <DataGridTextColumn Header="Цена" Binding="{Binding ProductSku.Price, StringFormat={}{0:N0} ₽}" Width="*" ElementStyle="{StaticResource CellCenter}"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="*" ElementStyle="{StaticResource CellCenter}"/>
                    <!-- Расчетная колонка Итого -->
                    <DataGridTextColumn Header="Итого" Binding="{Binding TotalPrice, StringFormat={}{0:N0} ₽}" Width="100" FontWeight="Bold" ElementStyle="{StaticResource CellCenter}"/>
                    <DataGridTemplateColumn Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Удалить" Click="DeleteCartItem_Click" Background="#FF4444" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <!-- Нижняя панель с суммой -->
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Общая сумма заказа: " FontSize="18" Foreground="#444"/>
                <TextBlock x:Name="TotalOrderSum" Text="0 ₽" FontSize="22" FontWeight="Black" Foreground="#E64A19"/>
            </StackPanel>
            <Button Content="Оформить заказ" Click="Checkout_Click" Margin="0,10,0,0" Padding="25,10" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Page>
