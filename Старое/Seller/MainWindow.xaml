<Window x:Class="Seller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Seller"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" Width="1000">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="10" Background="LightGray">
            <TextBlock Text="Seller ID:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="SellerIdInput" Width="60" Text="1" VerticalContentAlignment="Center"/>
            <Button x:Name="LoadButton" Content=" Загрузить" Width="90" Click="LoadSellerDashboard_Click" Margin="5,0,0,0"/>
            <TextBlock x:Name="SellerIdLabel" Text="Seller #1" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <TextBlock x:Name="StatusLabel" Text="Готов" Foreground="Green" VerticalAlignment="Center"/>
            <Button x:Name="AddProductButton" Content="Добавить товар" Width="140" Click="AddProductButton_Click"/>
            <Button x:Name="EditProductButton" Content="Изменить товар" Width="140" Click="EditProductButton_Click"/>
            <Button x:Name="DeleteProductButton" Content="Удалить товар" Width="140" Click="DeleteProductButton_Click"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <UniformGrid Grid.Row="0" Rows="2" Columns="4" Margin="0,0,0,30">
                <Border Background="White" CornerRadius="12" Padding="25" Margin="10"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="TotalProductsText" Text="0" 
                               FontSize="36" FontWeight="Bold" Foreground="#007BFF"
                               HorizontalAlignment="Center"/>
                        <TextBlock Text="Товаров" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="TotalSkusText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#007BFF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Вариантов (SKU)" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="TotalStockText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                        <TextBlock Text="Общий остаток" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="TotalOrdersText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#17A2B8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Заказов" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="ItemsSoldText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#FFC107" HorizontalAlignment="Center"/>
                        <TextBlock Text="Продано единиц" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="TotalRevenueText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                        <TextBlock Text="Выручка" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="AvgRatingText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#6F42C1" HorizontalAlignment="Center"/>
                        <TextBlock Text="Средний рейтинг" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
            <Grid Grid.Row="1" RenderTransformOrigin="0.505,0.512">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,15,0"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="0" 
        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Заголовок -->
                            <RowDefinition Height="*"/>
                            <!-- DataGrid -->
                        </Grid.RowDefinitions>

                        <!-- Заголовок таблицы -->
                        <Border Grid.Row="0" Background="#F8F9FA" CornerRadius="8" Margin="20,20,-458,15" Padding="20">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Продукты продавца" FontSize="20" FontWeight="Bold" 
                           VerticalAlignment="Center" Foreground="#333"/>
                                <TextBlock x:Name="ProductsCountLabel" Text="(0)" FontWeight="SemiBold" 
                           VerticalAlignment="Center" Margin="20,0,0,0" Foreground="#666"/>
                            </StackPanel>
                        </Border>

                        <!-- DataGrid с продуктами -->
                        <DataGrid x:Name="ProductsDataGrid" Grid.Row="1" Margin="20,0,-458,10" 
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Бренд" Binding="{Binding Brand}" Width="120"/>
                                <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="120"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='₽{0:N0}'}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Остаток" Binding="{Binding Stock}" Width="90" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Неактивен">
                                            <Setter Property="Background" Value="#FEF2F2"/>
                                            <Setter Property="Foreground" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
  

    </Window>
