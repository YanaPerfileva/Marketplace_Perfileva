<Window x:Class="Seller.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Seller"
        mc:Ignorable="d"
        Title="EditProductWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,30">
            <TextBlock x:Name="WindowTitle" Text="Редактировать товар" FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="#2C3E50"/>
            <TextBlock x:Name="ProductIdText" Text="" FontSize="16" FontWeight="SemiBold" 
                       Margin="0,10,0,0" Foreground="#495057"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Продавец:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="SellerIdInput" Width="80" IsReadOnly="True" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Выберите товар для редактирования:*" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ProductsComboBox" Height="35" FontSize="14" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"
                  SelectionChanged="ProductsComboBox_SelectionChanged"/>
                    </StackPanel>

                    <Button x:Name="EditSkusButton" Content="Редактировать SKU" Width="160" Height="35" 
            Margin="0,10,0,0" Click="EditSkusButton_Click"/>
                </StackPanel>

                <GroupBox Grid.Row="1" Header="Основная информация" Margin="0,0,0,20" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="Название:*" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="NameTextBox" Height="35" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                            <TextBlock Text="Бренд" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="BrandTextBox" Height="35" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                            <TextBlock Text="Базовая цена:*" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="PriceTextBox" Height="35" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="Категория:*" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <ComboBox x:Name="CategoryComboBox" Height="35" FontSize="14" 
                                      DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        </StackPanel>

                        <TextBox x:Name="DescriptionTextBox" Grid.Row="2" Grid.ColumnSpan="2" 
                                 Height="100" Margin="0,10,0,0" AcceptsReturn="True" TextWrapping="Wrap" 
                                 VerticalScrollBarVisibility="Auto" FontSize="14"/>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Row="2" Header="Главное изображение" Margin="0,0,0,20" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="MainImageText" Text="Изображение загружается..." 
                                       Foreground="Gray" Margin="0,0,0,10"/>
                            <Image x:Name="MainImagePreview" Height="200" Stretch="UniformToFill"></Image>
                                  
                        </StackPanel>
                        <Button x:Name="SelectMainImageButton" Grid.Column="1" Content="Изменить" 
                                Width="120" Height="40" Margin="10,50,0,0" Click="SelectMainImageButton_Click"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="Обновить товар" Width="140" Height="45" 
                    Click="SaveButton_Click" Background="#007BFF" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="120" Height="45" 
                    Click="CancelButton_Click" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
