<Window x:Class="Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Main"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
  
    <Border Background="White" CornerRadius="15" Margin="30" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.1"/>
        </Border.Effect>
        <Grid Background="#F0F2F5">
            <StackPanel x:Name="LoginPanel" Visibility="Visible">
                <TextBlock Text="Вход в аккаунт" FontSize="22" FontWeight="Bold" 
                          Margin="0,0,0,20" HorizontalAlignment="Center"/>
                <TextBlock Text="Email"/>
                <TextBox x:Name="LoginEmail" Height="35" Margin="0,5,0,15" 
                        VerticalContentAlignment="Center"/>
                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="LoginPass" Height="35" Margin="0,5,0,20" 
                           VerticalContentAlignment="Center"/>
                <Button Content="Войти" Click="BtnLogin_Click" Background="#28a745" 
                       Foreground="White" Height="40" FontWeight="Bold"/>
                <Button Content="Нет аккаунта? Регистрация" Click="TogglePanels_Click" 
                       Background="Transparent" BorderThickness="0" Foreground="#007BFF" Margin="0,10"/>
            </StackPanel>

            <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">
                <TextBlock Text="Регистрация" FontSize="22" FontWeight="Bold" 
                          Margin="0,0,0,15" HorizontalAlignment="Center"/>
                <TextBlock Text="ФИО" FontWeight="SemiBold"/>
                <TextBox x:Name="RegName" Height="30" Margin="0,5,0,10"/>

                <TextBlock Text="Телефон" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="RegPhone" Height="30" Margin="0,5,0,10" 
                        VerticalContentAlignment="Center" Padding="5,0" 
                        PreviewTextInput="RegPhone_PreviewTextInput" ToolTip="Формат: 89001234567" MaxLength="11"/>

                <TextBlock Text="Email" FontWeight="SemiBold"/>
                <TextBox x:Name="RegEmail" Height="30" Margin="0,5,0,10"/>

                <TextBlock Text="Пароль" FontWeight="SemiBold"/>
                <PasswordBox x:Name="RegPass" Height="30" Margin="0,5,0,15"/>

                <!-- ComboBox для выбора роли -->
                <TextBlock Text="Тип аккаунта" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="RoleComboBox" Height="30" Margin="0,5,0,15" FontSize="14">
                    <ComboBoxItem Content="Покупатель" IsSelected="True" Tag="buyer"/>
                    <ComboBoxItem Content="Продавец" Tag="seller"/>
                </ComboBox>

                <Button Content="Создать аккаунт" Click="BtnRegister_Click" 
                       Background="#007BFF" Foreground="White" Height="40" FontWeight="Bold"/>
                <Button Content="Уже есть аккаунт? Войти" Click="TogglePanels_Click" 
                       Background="Transparent" BorderThickness="0" Foreground="#666" Margin="0,10"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
