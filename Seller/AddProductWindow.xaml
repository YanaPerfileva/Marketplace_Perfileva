<Window x:Class="Seller.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Seller"
        mc:Ignorable="d"
        Title="AddProductWindow" Height="650" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="WindowTitle" Grid.Row="0" Text="Новый товар" 
               FontSize="28" FontWeight="Bold" Margin="0,0,0,30" 
               HorizontalAlignment="Center" Foreground="#2C3E50"/>
        <ScrollViewer Margin="0,67,0,1" Grid.RowSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Seller ID (только для отображения) -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="Продавец:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="SellerIdInput" Width="80" IsReadOnly="True" 
                         VerticalContentAlignment="Center" FontWeight="Bold"/>
                </StackPanel>

                <!-- Основная информация -->
                <GroupBox Grid.Row="1" Header="Основная информация" Margin="0,0,0,20" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                            <TextBlock Text="Название товара:*" Margin="0,0,0,5"/>
                            <TextBox x:Name="NameTextBox" Height="35"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                            <TextBlock Text="Бренд" Margin="0,0,0,5"/>
                            <TextBox x:Name="BrandTextBox" Height="35"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                            <TextBlock Text="Цена:*" Margin="0,0,0,5"/>
                            <TextBox x:Name="PriceTextBox" Height="35"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="Категория:*" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CategoryComboBox" Height="35" DisplayMemberPath="Name" 
                                  SelectedValuePath="Id"/>
                        </StackPanel>

                        <TextBox x:Name="DescriptionTextBox" Grid.Row="2" Grid.ColumnSpan="2" 
                             Height="100" Margin="0,10,0,0" AcceptsReturn="True" 
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Главное изображение" Margin="0,0,0,20" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="MainImageText" Text="Выберите главное изображение" 
                                   Foreground="Gray" Margin="0,0,0,10"/>
                            <Image x:Name="MainImagePreview" Height="200" Stretch="UniformToFill" />

                        </StackPanel>

                        <Button x:Name="SelectMainImageButton" Grid.Column="1" Content="Выбрать" 
                            Width="120" Height="40" Margin="10,50,0,0" Click="SelectMainImageButton_Click"/>
                    </Grid>
                </GroupBox>

                
                
            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,96,0,-76">
            <Button x:Name="SaveButton" Content="Сохранить" Width="120" Height="45" 
                FontSize="16" FontWeight="Bold" Margin="0,0,10,0" Click="SaveButton_Click"
                Background="#28A745" Foreground="White"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="120" Height="45" 
                FontSize="16" Click="CancelButton_Click"/>
        </StackPanel>
        <GroupBox Grid.Row="3" Header="Варианты товара (SKU)" Margin="0,0,0,20" Padding="15">
            <Grid Height="113" Margin="0,0,-9,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="Размер:*" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="SkuSizeTextBox" Height="35" Text="" FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,10">
                        <TextBlock Text="Цвет:*" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="SkuColorTextBox" Height="35" Text="" FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Text="HEX код цвета" Margin="0,0,0,5"/>
                        <TextBox x:Name="SkuColorHexTextBox" Height="35" Text="#" FontSize="14"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="Цена SKU:*" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="SkuPriceTextBox" Height="35" Text="" FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="Остаток:*" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="SkuStockTextBox" Height="35" Text="" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
