<Window x:Class="Seller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Seller"
        mc:Ignorable="d"
        Title="Администратор" Height="900" Width="1000">
    <Grid Margin="20">
        <Grid.Resources>
            <!-- Анимация появления для всех карточек -->
            <Storyboard x:Key="FadeIn">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                             From="20" To="0" Duration="0:0:0.4"/>
            </Storyboard>

            <Style x:Key="StatCardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="15"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
                    </EventTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Верхний тулбар -->
            <RowDefinition Height="Auto"/>
            <!-- Блок карточек (7 штук) -->
            <RowDefinition Height="*"/>
            <!-- Таблица продуктов -->
        </Grid.RowDefinitions>

        <!-- 1. ВЕРХНЯЯ ПАНЕЛЬ (СОХРАНЕНЫ ВСЕ КНОПКИ) -->
        <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="15,10" Margin="8,0,8,0" >
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Левая часть: ID и Загрузка -->
                    <ColumnDefinition Width="*"/>
                    <!-- Пробел -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Правая часть: Кнопки действий -->
                </Grid.ColumnDefinitions>

                <!-- ЛЕВАЯ СТОРОНА -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛒" FontSize="24" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Text="ID:" VerticalAlignment="Center" Foreground="#718096" Margin="0,0,5,0"/>
                    <TextBox x:Name="SellerIdInput" Width="45" Text="1" 
         Style="{StaticResource ModernInput}" 
         Margin="0,0,10,0" 
         PreviewMouseDown="If_seller"  
                   />
                        <Button x:Name="LoadButton" Content="Загрузить" Width="116" Height="43" 
                    Style="{StaticResource RoundedButtonStyle}" Click="LoadSellerDashboard_Click"/>

                    <Separator Margin="15,5" Background="#E2E8F0"/>

                    <TextBlock x:Name="SellerIdLabel" Text="Seller #1" FontWeight="Bold" VerticalAlignment="Center" Foreground="#2D3748"/>
                    <TextBlock x:Name="StatusLabel" Text="● Готов" Foreground="#48BB78" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <!-- ПРАВАЯ СТОРОНА (Действия) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="AddProductButton" Content="Добавить" Width="110" Height="43" 
                    Style="{StaticResource RoundedButtonStyle}" Margin="4,0" Click="AddProductButton_Click"/>

                    <Button x:Name="EditProductButton" Content="Изменить" Width="110" Height="43"
                    Background="#EDF2F7" Foreground="#4A5568" 
                    Style="{StaticResource RoundedButtonStyle}" Margin="4,0" Click="EditProductButton_Click"/>

                    <Button x:Name="DeleteProductButton" Content="Удалить" Width="110" Height="43" 
                    Background="#FFF5F5" Foreground="#F56565" 
                    Style="{StaticResource RoundedButtonStyle}" Margin="4,0" Click="DeleteProductButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. СЕТКА КАРТОЧЕК (ВСЕ 7 ЭЛЕМЕНТОВ) -->
        <UniformGrid Grid.Row="1" Rows="2" Columns="4" Margin="0,0,0,15">
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="TotalProductsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#007BFF" HorizontalAlignment="Center"/>
                    <TextBlock Text="Товаров" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="TotalSkusText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#007BFF" HorizontalAlignment="Center"/>
                    <TextBlock Text="Вариантов (SKU)" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="TotalStockText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                    <TextBlock Text="Общий остаток" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="TotalOrdersText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#17A2B8" HorizontalAlignment="Center"/>
                    <TextBlock Text="Заказов" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="ItemsSoldText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#FFC107" HorizontalAlignment="Center"/>
                    <TextBlock Text="Продано единиц" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="TotalRevenueText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                    <TextBlock Text="Выручка" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="AvgRatingText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#6F42C1" HorizontalAlignment="Center"/>
                    <TextBlock Text="Средний рейтинг" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Пустая карточка для симметрии или логотипа -->
            <Border Background="Transparent" Margin="10"/>
        </UniformGrid>

        <!-- 3. ТАБЛИЦА (ИСПРАВЛЕНА СЕТКА) -->
        <Border Grid.Row="2" Background="White" CornerRadius="20" Margin="8" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Продукты продавца" FontSize="18" FontWeight="Bold" Foreground="#333"/>
                    <TextBlock x:Name="ProductsCountLabel" Text="(0)" Foreground="#999" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <DataGrid x:Name="ProductsDataGrid" Grid.Row="1" 
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      BorderThickness="0" 
                      IsReadOnly="True" RowHeight="42">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" ElementStyle="{StaticResource CellCenter}"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource CellCenter}"/>
                        <DataGridTextColumn Header="Бренд" Binding="{Binding Brand}" Width="120" ElementStyle="{StaticResource CellCenter}"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="120" ElementStyle="{StaticResource CellCenter}"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='{}{0:N0} ₽'}" Width="100" ElementStyle="{StaticResource CellCenter}"/>
                        <DataGridTextColumn Header="Остаток" Binding="{Binding Stock}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                        <DataGridTemplateColumn Header="Статус" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="StatusBadge" CornerRadius="6" Padding="6,2">
                                        <TextBlock Text="{Binding Status}" FontSize="11" HorizontalAlignment="Center"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Неактивен">
                                            <Setter TargetName="StatusBadge" Property="Background" Value="#FFE5E5"/>
                                            <Setter TargetName="StatusBadge" Property="TextBlock.Foreground" Value="#D32F2F"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Активен">
                                            <Setter TargetName="StatusBadge" Property="Background" Value="#E5F9E5"/>
                                            <Setter TargetName="StatusBadge" Property="TextBlock.Foreground" Value="#388E3C"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
