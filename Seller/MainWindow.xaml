<Window x:Class="Seller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Seller"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="1000">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="10" Background="LightGray">
            <TextBlock Text="Seller ID:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="SellerIdInput" Width="60" Text="1" VerticalContentAlignment="Center"/>
            <Button x:Name="LoadButton" Content=" Загрузить" Width="90" Click="LoadSellerDashboard_Click" Margin="5,0,0,0"/>
            <TextBlock x:Name="SellerIdLabel" Text="Seller #1" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <TextBlock x:Name="StatusLabel" Text="Готов" Foreground="Green" VerticalAlignment="Center"/>
            <Button x:Name="AddProductButton" Content="Добавить товар" Width="140" Click="AddProductButton_Click"/>
            <Button x:Name="EditProductButton" Content="Изменить товар" Width="140" Click="EditProductButton_Click"/>
            <Button x:Name="DeleteProductButton" Content="Удалить товар" Width="140" Click="DeleteProductButton_Click"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <UniformGrid Grid.Row="0" Rows="2" Columns="4" Margin="0,0,0,30">
                <Border Background="White" CornerRadius="12" Padding="25" Margin="10"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="TotalProductsText" Text="0" 
                               FontSize="36" FontWeight="Bold" Foreground="#007BFF"
                               HorizontalAlignment="Center"/>
                        <TextBlock Text="Товаров" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="TotalSkusText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#007BFF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Вариантов (SKU)" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="TotalStockText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                        <TextBlock Text="Общий остаток" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="TotalOrdersText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#17A2B8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Заказов" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="ItemsSoldText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#FFC107" HorizontalAlignment="Center"/>
                        <TextBlock Text="Продано единиц" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="TotalRevenueText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                        <TextBlock Text="Выручка" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="AvgRatingText" Text="0" FontSize="36" 
                               FontWeight="Bold" Foreground="#6F42C1" HorizontalAlignment="Center"/>
                        <TextBlock Text="Средний рейтинг" FontSize="14" Foreground="#666"
                               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,15,0"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Топ-5 товаров" FontSize="20" 
                               FontWeight="Bold" Margin="25,25,25,15" Foreground="#333"/>

                        <ListView x:Name="TopProductsListView" Grid.Row="1" Margin="25">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" Margin="0,0,0,10" CornerRadius="8" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                            <TextBlock Text="{Binding Brand}" Foreground="#666" Margin="0,5"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <TextBlock Text="Заказов:" Margin="0,0,15,0"/>
                                                <TextBlock Text="{Binding OrdersCount}"/>
                                                <TextBlock Text="Продано:" Margin="15,0,15,0"/>
                                                <TextBlock Text="{Binding SoldCount}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Revenue, StringFormat='Выручка: ₽{0:N}'}" 
                                                   FontWeight="SemiBold" Foreground="#28A745"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="15,0,0,0"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Низкие остатки (≤10)" FontSize="20" 
                               FontWeight="Bold" Margin="25,25,25,15" Foreground="#DC3545"/>

                        <ListView x:Name="LowStockListView" Grid.Row="1" Margin="25">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF3CD" Margin="0,0,0,10" CornerRadius="8" 
                                        Padding="20" BorderBrush="#FFEAA7" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <TextBlock Text="{Binding Size, StringFormat=' {0} | '}" 
                                                       Foreground="#666"/>
                                                <TextBlock Text="{Binding Color}" Foreground="#666"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Stock, StringFormat='Остаток: {0} шт'}" 
                                                   FontSize="18" FontWeight="Bold" Foreground="#DC3545"/>
                                            <!--<Button Content="Пополнить" Width="100" Height="35" Margin="0,10,0,0"></Button>
                                            Background="#007BFF" Foreground="White" Click="ReplenishStock_Click"/>-->
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
